@article{collaborationFirstSagittariusEvent2022,
  title = {First {{Sagittarius A}}* {{Event Horizon Telescope Results}}. {{I}}. {{The Shadow}} of the {{Supermassive Black Hole}} in the {{Center}} of the {{Milky Way}}},
  author = {Collaboration, The Event Horizon Telescope},
  year = 2022,
  month = may,
  journal = {The Astrophysical Journal Letters},
  volume = {930},
  number = {2},
  eprint = {2311.08680},
  primaryclass = {astro-ph},
  pages = {L12},
  issn = {2041-8205, 2041-8213},
  doi = {10.3847/2041-8213/ac6674},
  urldate = {2026-04-15},
  abstract = {We present the first Event Horizon Telescope (EHT) observations of Sagittarius A* (Sgr A\$\textasciicircum *\$), the Galactic center source associated with a supermassive black hole. These observations were conducted in 2017 using a global interferometric array of eight telescopes operating at a wavelength of \${$\lambda$}=1.3\textbackslash,\textbraceleft\textbackslash rm mm\textbraceright\$. The EHT data resolve a compact emission region with intrahour variability. A variety of imaging and modeling analyses all support an image that is dominated by a bright, thick ring with a diameter of \$51.8 \textbackslash pm 2.3\$\textbackslash,\textbackslash uas (68\textbackslash\% credible interval). The ring has modest azimuthal brightness asymmetry and a comparatively dim interior. Using a large suite of numerical simulations, we demonstrate that the EHT images of Sgr A\$\textasciicircum *\$ are consistent with the expected appearance of a Kerr black hole with mass \$\textbraceleft\textbackslash sim\textbraceright 4 \textbackslash times 10\textasciicircum 6\textbackslash,\textbraceleft\textbackslash rm M\textbraceright\_\textbackslash odot\$, which is inferred to exist at this location based on previous infrared observations of individual stellar orbits as well as maser proper motion studies. Our model comparisons disfavor scenarios where the black hole is viewed at high inclination (\$i {$>$} 50\textasciicircum\textbackslash circ\$), as well as non-spinning black holes and those with retrograde accretion disks. Our results provide direct evidence for the presence of a supermassive black hole at the center of the Milky Way galaxy, and for the first time we connect the predictions from dynamical measurements of stellar orbits on scales of \$10\textasciicircum 3-10\textasciicircum 5\$ gravitational radii to event horizon-scale images and variability. Furthermore, a comparison with the EHT results for the supermassive black hole M87\$\textasciicircum *\$ shows consistency with the predictions of general relativity spanning over three orders of magnitude in central mass.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - High Energy Astrophysical Phenomena},
  file = {/home/daniel/snap/zotero-snap/common/Zotero/storage/9A83TD9P/Collaboration - 2022 - First Sagittarius A Event Horizon Telescope Results. I. The Shadow of the Supermassive Black Hole i.pdf;/home/daniel/snap/zotero-snap/common/Zotero/storage/6W7KJ6T2/2311.html}
}

